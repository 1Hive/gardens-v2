{
  "name": "foundry",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "make deploy",
    "fork": "make fork",
    "build": "forge build --sizes --root ../.. pkg/contracts/src",
    "postbuild": "node scripts/aggregate-diamond-abi.js",
    "build:ir": "forge build --sizes --via-ir",
    "lint": "forge fmt",
    "test": "forge test -vvv",
    "test:force": "forge test -vvv --force",
    "test:fork-healthcheck": "forge test --match-contract ForkLifecycleHealthcheck -vvv",
    "format": "forge fmt",
    "coverage": "forge coverage --ir-minimum --no-match-path '*Fork*' --match-path 'pkg/contracts/test/**' --skip 'pkg/contracts/script/**' --exclude-tests --report lcov -r lcov.info && sed -i 's|^SF:pkg/contracts/|SF:|g' lcov.info",
    "sync:abis": "bash scripts/sync-abis.sh"
  }
}
{
  "editor.formatOnSave": false,
  "[solidity]": {
    "editor.formatOnSave": false,
    "editor.defaultFormatter": "NomicFoundation.hardhat-solidity"
  },
  "files.watcherExclude": {
    "**/abis/**": true,
    "**/broadcast/**": true,
    "**/cache/**": true,
    "**/out/**": true,
    "**/lib/**/cache/**": true,
    "**/lib/**/out/**": true
  },
  "search.exclude": {
    "**/abis/**": true,
    "**/broadcast/**": true,
    "**/cache/**": true,
    "**/out/**": true
  }
}
